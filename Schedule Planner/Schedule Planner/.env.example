# App expose ports on host machine
APP_PORT=3000
DB_PORT=5432

# Postgres service credentials in docker-compose
POSTGRES_DB=schedule_planner
POSTGRES_USER=planner
POSTGRES_PASSWORD=planner

# App database connection string (inside docker network)
DATABASE_URL=postgresql://planner:planner@db:5432/schedule_planner

# Default single-user profile used by current planner APIs
PLANNER_DEFAULT_USER_ID=00000000-0000-0000-0000-000000000001
PLANNER_DEFAULT_TIMEZONE=Asia/Ho_Chi_Minh
AUTH_SESSION_SECRET=change-this-secret-in-production
NEXT_PUBLIC_SUPPORT_EMAIL=support@your-domain.com

# Nango integration settings
NANGO_SECRET_KEY=
NANGO_BASE_URL=https://api.nango.dev
NANGO_WEBHOOK_SECRET=
NANGO_INTEGRATION_GMAIL=
NANGO_INTEGRATION_TELEGRAM=
NANGO_TELEGRAM_SEND_PATH=/proxy/sendMessage
NANGO_TELEGRAM_UPDATES_PATH=/proxy/getUpdates
NANGO_TELEGRAM_DELETE_WEBHOOK_PATH=/proxy/deleteWebhook
TELEGRAM_DEFAULT_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET_TOKEN=
INTERNAL_SCHEDULER_TOKEN=dev-scheduler-token
SCHEDULER_APP_BASE_URL=http://app:3000
REMINDER_SCHEDULER_ENABLED=true
REMINDER_DISPATCH_INTERVAL_MS=5000
REMINDER_DISPATCH_LIMIT=20
TELEGRAM_POLL_ENABLED=true
TELEGRAM_POLL_INTERVAL_MS=1500
TELEGRAM_POLL_BATCH_LIMIT=20
TELEGRAM_POLL_DELETE_WEBHOOK_ON_CONFLICT=true

# Router provider: rule | mistral | auto
ROUTER_PROVIDER=rule

# Mistral AI settings (set key to enable LLM router)
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest
MISTRAL_API_URL=https://api.mistral.ai/v1/chat/completions
MISTRAL_TIMEOUT_MS=15000
