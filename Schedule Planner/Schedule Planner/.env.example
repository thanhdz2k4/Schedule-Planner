# App expose ports on host machine
APP_PORT=3000
DB_PORT=5432

# Postgres service credentials in docker-compose
POSTGRES_DB=schedule_planner
POSTGRES_USER=planner
POSTGRES_PASSWORD=planner

# App database connection string (inside docker network)
DATABASE_URL=postgresql://planner:planner@db:5432/schedule_planner

# Default single-user profile used by current planner APIs
PLANNER_DEFAULT_USER_ID=00000000-0000-0000-0000-000000000001
PLANNER_DEFAULT_TIMEZONE=Asia/Ho_Chi_Minh
